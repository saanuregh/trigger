TRIGGER_NAMESPACES=production,staging

# GitHub file URL or local path
TRIGGER_PRODUCTION_CONFIG=https://github.com/saanuregh/trigger/blob/main/examples/configs/production.yaml
TRIGGER_STAGING_CONFIG=https://github.com/saanuregh/trigger/blob/main/examples/configs/staging.yaml

# GitHub token — used for fetching configs from private repos
GITHUB_TOKEN=ghp_xxx

# Optional — only needed if using cloudflare-purge actions
CLOUDFLARE_API_TOKEN=xxx
CLOUDFLARE_ZONE_ID=xxx

PORT=3000
DATA_DIR=./data

# Custom actions directory — place .ts files here to register custom pipeline actions
ACTIONS_DIR=./actions

# Max concurrent pipeline runs across all pipelines (default: 10)
# MAX_CONCURRENT_RUNS=10

# Env var injection — reference env vars in configs via {{env.X}}
# Only vars with this prefix are accessible (default: TRIGGER_ENV_)
# TRIGGER_ENV_PREFIX=TRIGGER_ENV_
# Example: {{env.DB_PASSWORD}} resolves to TRIGGER_ENV_DB_PASSWORD
# TRIGGER_ENV_STAGING_DB_PASSWORD=s3cret

# Auth (optional — set OIDC_ISSUER to enable SSO)
# OIDC_ISSUER=https://auth.example.com/realms/myapp
# OIDC_CLIENT_ID=trigger
# OIDC_CLIENT_SECRET=xxx
# TRIGGER_ADMINS=admin@example.com,admin2@example.com
