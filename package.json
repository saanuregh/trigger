{
  "name": "@saanuregh/trigger",
  "version": "0.5.3",
  "description": "Trigger and monitor deployment pipelines with declarative YAML configs and a real-time web UI",
  "module": "index.ts",
  "type": "module",
  "license": "MIT",
  "author": "saanuregh",
  "repository": {
    "type": "git",
    "url": "https://github.com/saanuregh/trigger.git"
  },
  "keywords": [
    "deployment",
    "pipeline",
    "ci-cd",
    "bun",
    "devops"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "bin": {
    "trigger": "index.ts"
  },
  "scripts": {
    "dev": "bun --hot index.ts start",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun build.ts",
    "start": "cd dist && bun index.js start",
    "validate": "bun index.ts validate examples/configs/*.yaml",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "format": "bunx biome format --write ."
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.989.0",
    "@aws-sdk/client-codebuild": "^3.989.0",
    "@aws-sdk/client-ecs": "^3.989.0",
    "croner": "^10.0.1",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4.1.18"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
